# Bot Factory Configuration
# Скопируйте в .env и измените значения для вашего сервера
# Copy to .env and modify values for your server

# ============================================
# СЕРВЕР / SERVER
# ============================================

# Адрес для запуска (0.0.0.0 для всех интерфейсов, 127.0.0.1 только локально)
# Host to bind to (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
BF_HOST=0.0.0.0

# Порт для запуска
# Port to listen on
BF_PORT=8000

# ============================================
# БЕЗОПАСНОСТЬ / SECURITY
# ============================================

# Разрешить удалённый доступ к API (по умолчанию - только локально)
# Allow remote API access (default: localhost only)
BF_ALLOW_REMOTE=0

# Токен для защиты API (оставить пустым если BF_ALLOW_REMOTE=0)
# API token for security (leave empty if BF_ALLOW_REMOTE=0)
BF_ADMIN_TOKEN=

# Разрешить API доступ к системным файлам
# Allow API access to system files
BF_ENABLE_SYSTEM_FILES_API=0
